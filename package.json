{
  "name": "rehoyo-global-player-intelligence",
  "description": "ReHoYo Electron command center for grounded public-web game research agents and deterministic demos.",
  "author": "ReHoYo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently --kill-others --success first -n renderer,electron -c cyan,magenta \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "start": "npm run build && electron .",
    "build": "tsc -b && vite build",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node tests/e2e/run.mjs",
    "test:electron": "npm run build && playwright test --config electron.playwright.config.ts",
    "check": "npm run test && npm run build"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.3.0",
    "@fontsource/noto-sans-sc": "^5.3.0",
    "@fontsource/space-grotesk": "^5.3.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.21",
    "@radix-ui/react-scroll-area": "^1.2.16",
    "@radix-ui/react-tabs": "^1.1.19",
    "@radix-ui/react-tooltip": "^1.2.14",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "motion": "^12.42.2",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wait-on": "^9.1.0"
  },
  "build": {
    "appId": "com.rehoyo.player-intelligence",
    "productName": "ReHoYo",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "ReHoYo_Logo_Transparent.png",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "ReHoYo_Logo_Transparent.png",
      "artifactName": "ReHoYo-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
